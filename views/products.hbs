{{!< main}}

<section class="products-container">

    <h2 class="title">PRODUCTOS DISPONIBLES</h2>

    <div class="cards">

        {{#each products}}
        <div class="card">

            <div class="img-box">
                <img src="{{this.image}}" alt="{{this.name}}" class="product-img">
            </div>

            <h3>{{this.name}}</h3>

            <p class="price">$ {{formatPrice this.price}}</p>

            <p class="stock">Stock: {{this.stock}}</p>

            <!-- 🔥 CAMBIO: usar _id -->
            <div class="quantity">
                <button onclick="restar('{{this._id}}')">-</button>
                <span id="cantidad-{{this._id}}">1</span>
                <button onclick="sumar('{{this._id}}')">+</button>
            </div>

            <!-- 🔥 CAMBIO: usar _id -->
            <button class="btn-cart" onclick="agregarCarrito('{{this._id}}')">
                Agregar al carrito
            </button>

        </div>
        {{/each}}

    </div>

</section>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
function sumar(id) {
    const span = document.getElementById(`cantidad-${id}`)
    span.innerText = parseInt(span.innerText) + 1
}

function restar(id) {
    const span = document.getElementById(`cantidad-${id}`)
    let cantidad = parseInt(span.innerText)
    if (cantidad > 1) {
        span.innerText = cantidad - 1
    }
}

async function agregarCarrito(id) {

    console.log("🆔 ID FRONT:", id);

    const cantidad = parseInt(document.getElementById(`cantidad-${id}`).innerText)

    const res = await fetch('/api/cart', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
            id: id, // 🔥 YA NO Number()
            quantity: cantidad
        })
    });

    const data = await res.json();
    console.log("📦 RESPUESTA:", data);

    Swal.fire({
        icon: 'success',
        title: 'Producto agregado',
        text: `Se añadieron ${cantidad} unidad(es) al carrito`,
        showConfirmButton: false,
        timer: 1500
    });
}
</script>